# Foundry / Responses API (recommended for your deployment)
AZURE_OPENAI_API_MODE=responses
AZURE_OPENAI_RESPONSES_URL=https://kanne-mcl97av9-eastus2.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview

# Azure OpenAI chat endpoint (only needed if using Chat Completions)
AZURE_OPENAI_ENDPOINT=https://kanne-mcl97av9-eastus2.openai.azure.com
AZURE_OPENAI_BASE_URL=https://kanne-mcl97av9-eastus2.openai.azure.com/openai/v1

# Put your real key here (do not share it)
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_API_KEY_HERE
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Deployment name you created in Azure OpenAI / Foundry
AZURE_OPENAI_DEPLOYMENT=gpt-5.2-chat

# Optional: deployment map (label=deployment). If set, app will use the right side.
AZURE_OPENAI_DEPLOYMENT_NAME_MAP=gpt-5.2-chat=gpt-5.2-chat,gpt-4.1-mini=gpt-4.1-mini,gpt-35-turbo=gpt-35-turbo,gpt-35-turbo-2=gpt-35-turbo-2,o4-mini=o4-mini,grok-3=grok-3

# Optional: per-deployment URL overrides (label=full_url)
AZURE_OPENAI_DEPLOYMENT_URL_MAP=gpt-35-turbo=https://kanne-mcl97av9-eastus2.cognitiveservices.azure.com/openai/deployments/gpt-35-turbo/chat/completions?api-version=2025-01-01-preview,gpt-35-turbo-2=https://kanne-mcl97av9-eastus2.cognitiveservices.azure.com/openai/deployments/gpt-35-turbo-2/chat/completions?api-version=2025-01-01-preview,gpt-4.1-mini=https://kanne-mcl97av9-eastus2.cognitiveservices.azure.com/openai/deployments/gpt-4.1-mini/chat/completions?api-version=2025-01-01-preview,grok-3=https://kanne-mcl97av9-eastus2.services.ai.azure.com/models/chat/completions?api-version=2024-05-01-preview,o4-mini=https://kanne-mcl97av9-eastus2.cognitiveservices.azure.com/openai/deployments/o4-mini/chat/completions?api-version=2025-01-01-preview

# Optional tuning
AZURE_OPENAI_MAX_OUTPUT_TOKENS=400
# AZURE_OPENAI_RESPONSES_TEMPERATURE=0.7  # only if your model supports temperature
AZURE_OPENAI_MAX_TOKENS=400
AZURE_OPENAI_TEMPERATURE=0.7
